# Database
DATABASE_URL=postgresql+asyncpg://cashflow:cashflow_dev@localhost:5432/cashflow_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:9999

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_ENV=sandbox

# Ratiba API
RATIBA_API_KEY=
RATIBA_BASE_URL=https://api.ratiba.io
RATIBA_WEBHOOK_URL=https://your-domain.com/webhooks/ratiba

# OpenRouter AI
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Africa's Talking SMS
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=

# eSMS Mail API (https://esmsafrica.io)
ESMS_API_KEY=
ESMS_FROM_EMAIL=hello@yourdomain.com
ESMS_FROM_NAME=CashFlow AI
APP_URL=https://yourdomain.com
